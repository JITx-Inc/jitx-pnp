<?xml version="1.0" encoding="UTF-8"?>
<PROJECT>
  <BOARD>
    <!-- C10 sorts after C2 under natural sort, even though C10 comes first in XML -->
    <INST DESIGNATOR="C10" SIDE="Top" PACKAGE="Pkg0402">
      <POSE X="10.000" Y="20.000" ANGLE="90.000"/>
    </INST>
    <INST DESIGNATOR="C2" SIDE="Top" PACKAGE="Pkg0402">
      <POSE X="5.000" Y="5.000" ANGLE="0.000"/>
    </INST>
    <!-- Bottom side; PACKAGE has $-suffix that should be truncated -->
    <INST DESIGNATOR="R1" SIDE="Bottom" PACKAGE="Pkg0805$alt">
      <POSE X="3.000" Y="4.000" ANGLE="180.000"/>
    </INST>
    <!-- Mixed-case SIDE; should normalize to Top -->
    <INST DESIGNATOR="U1" SIDE="TOP" PACKAGE="QFN-32">
      <POSE X="50.5" Y="60.6" ANGLE="270.0"/>
    </INST>
    <!-- Unknown SIDE; should default to Top with a warning -->
    <INST DESIGNATOR="J1" SIDE="Side1" PACKAGE="Connector">
      <POSE X="100" Y="200" ANGLE="0"/>
    </INST>
    <!-- Missing DESIGNATOR; should be skipped with a warning -->
    <INST SIDE="Top" PACKAGE="Mystery">
      <POSE X="1" Y="2" ANGLE="0"/>
    </INST>
    <!-- Missing POSE; should be skipped with a warning -->
    <INST DESIGNATOR="X1" SIDE="Top" PACKAGE="NoPose"/>
    <!-- L1 has no matching SCH-INST entry; PN should be empty -->
    <INST DESIGNATOR="L1" SIDE="Top" PACKAGE="Inductor">
      <POSE X="0" Y="0" ANGLE="0"/>
    </INST>
    <!-- Non-numeric POSE values; _safe_float should fall back to 0.0 -->
    <INST DESIGNATOR="D1" SIDE="Top" PACKAGE="LED">
      <POSE X="garbage" Y="" ANGLE="abc"/>
    </INST>
  </BOARD>
  <SCHEMATIC>
    <SHEET>
      <SCH-INST>
        <PROPS DESIGNATOR="C2" MPN="CGA2B3X7R1H103M050BB"/>
      </SCH-INST>
      <SCH-INST>
        <PROPS DESIGNATOR="C10" MPN="04023D105KAT2A"/>
      </SCH-INST>
      <!-- Multi-unit: two SCH-INST entries share DESIGNATOR=U1; first wins -->
      <SCH-INST>
        <PROPS DESIGNATOR="U1" MPN="STM32F103C8T6"/>
      </SCH-INST>
      <SCH-INST>
        <PROPS DESIGNATOR="U1" MPN="WRONG-SHOULD-NOT-WIN"/>
      </SCH-INST>
      <!-- CSV injection: leading = should be quote-escaped -->
      <SCH-INST>
        <PROPS DESIGNATOR="R1" MPN="=DANGEROUS"/>
      </SCH-INST>
      <!-- CSV injection: leading + should be quote-escaped -->
      <SCH-INST>
        <PROPS DESIGNATOR="J1" MPN="+1234"/>
      </SCH-INST>
      <!-- PROPS without DESIGNATOR is a no-op -->
      <SCH-INST>
        <PROPS/>
      </SCH-INST>
    </SHEET>
  </SCHEMATIC>
</PROJECT>
